# PostForge — Environment Configuration
# Copy this file to .env and fill in your values

# ─── Application ───────────────────────────────────────────────
APP_NAME=PostForge
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-this-to-a-secure-random-string

# ─── AI Provider ───────────────────────────────────────────────
# Anthropic Claude (primary)
ANTHROPIC_API_KEY=sk-ant-...your-key-here...
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (fallback, optional)
OPENAI_API_KEY=sk-...your-key-here...

# ─── Default Brand ─────────────────────────────────────────────
DEFAULT_BRAND=confluex

# ─── Storage Paths ─────────────────────────────────────────────
INPUT_INBOX_DIR=input/inbox
INPUT_PROCESSED_DIR=input/processed
OUTPUT_POSTS_DIR=output/final_posts
OUTPUT_CAPTIONS_DIR=output/captions
OUTPUT_METADATA_DIR=output/metadata
OUTPUT_LOGS_DIR=output/logs
CONFIG_BRANDS_DIR=config/brands
ASSETS_DIR=assets
FONTS_DIR=fonts

# ─── Database ──────────────────────────────────────────────────
DATABASE_URL=sqlite:///./postforge.db

# ─── Image Generation ──────────────────────────────────────────
IMAGE_WIDTH=1080
IMAGE_HEIGHT=1080
IMAGE_FORMAT=PNG
IMAGE_QUALITY=95

# ─── Watcher ───────────────────────────────────────────────────
WATCHER_ENABLED=true
WATCHER_INTERVAL=5

# ─── Future Integrations (stubs) ───────────────────────────────
# Meta Graph API
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
INSTAGRAM_API_VERSION=v21.0

# Google Drive
GOOGLE_DRIVE_CREDENTIALS_FILE=
GOOGLE_DRIVE_FOLDER_ID=

# Canva
CANVA_API_KEY=
CANVA_TEMPLATE_ID=

# Webhooks
WEBHOOK_SECRET=
WEBHOOK_PUBLISH_URL=
